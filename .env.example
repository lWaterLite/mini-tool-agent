# Copy this file to .env and fill in your real values.
# Never commit your real .env file.

# You can use OPENAI_API_KEY instead if you prefer.
LLM_API_KEY=your_api_key_here

# Pick a model that your account/provider supports.
LLM_MODEL=gpt-4o-mini

# Optional. Leave empty for the default OpenAI endpoint.
# For an OpenAI-compatible provider, set its base URL here.
LLM_BASE_URL=

# Defaults used by ask_llm.py when CLI arguments are not provided.
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800

