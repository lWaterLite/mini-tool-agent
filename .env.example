# 复制这个文件为 .env，然后填写真实配置。
# 不要把真实 .env 文件提交到 Git。

# 如果你更习惯使用 OPENAI_API_KEY，也可以改用它。
LLM_API_KEY=your_api_key_here

# 填写你的账号或模型供应商支持的模型名称。
LLM_MODEL=gpt-4o-mini

# 可选。留空时使用默认 OpenAI 接口地址。
# 如果使用 OpenAI 兼容供应商，在这里填写它的 base URL。
LLM_BASE_URL=

# 当命令行没有传入对应参数时，ask_llm.py 会使用这些默认值。
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
