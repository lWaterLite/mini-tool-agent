# 复制这个文件为 .env，然后填写真实配置。
# 不要把真实 .env 文件提交到 Git。

# FastAPI 服务配置
APP_NAME=mini-tool-agent
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# 文件搜索工具只允许在这个目录下搜索。
FILE_SEARCH_ROOT=documents

# Agent 与工具限制
MAX_FILE_SEARCH_RESULTS=5
MAX_AGENT_STEPS=4

# Agent planner 模式：
# - mock：默认规则型 planner，不调用真实 LLM，适合学习和测试。
# - llm：调用真实 OpenAI 兼容模型生成工具计划。
AGENT_PLANNER_MODE=mock

# 可选：如果你把计算器工具的限制配置化，可以在代码中读取这个值。
# 当前项目默认仍由工具内部策略控制，子模块7练习中可以继续优化。
CALCULATOR_MAX_POWER_EXPONENT=8

# 如果使用 AGENT_PLANNER_MODE=llm，需要填写真实 key。
# 如果你更习惯使用 OPENAI_API_KEY，也可以改用 OPENAI_API_KEY。
LLM_API_KEY=your_api_key_here

# 填写你的账号或模型供应商支持的模型名称。
LLM_MODEL=gpt-4o-mini

# 可选。留空时使用默认 OpenAI 接口地址。
# 如果使用 OpenAI 兼容供应商，在这里填写它的 base URL。
LLM_BASE_URL=

# LLM 默认参数。当前子模块 5 使用 mock planner，不会调用真实 LLM；
# 这些配置是为你后续替换真实模型预留的。
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
